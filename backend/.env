# backend/.env

# Port untuk server
PORT=5000

# JWT Secret Key (Ganti dengan string random yang kamu buat sendiri)
JWT_SECRET=rahasia_jwt_kamu_ganti_dengan_string_random_panjang_12345

# Node Environment
NODE_ENV=development

# SQLite Database akan otomatis dibuat sebagai file 'database.sqlite' 
# di folder backend, TIDAK PERLU KONFIGURASI APAPUN!